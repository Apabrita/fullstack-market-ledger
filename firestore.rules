rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'pin', 'role']) && 
             data.keys().size() == 4 &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.pin is string && data.pin.size() <= 10 &&
             data.role in ['admin', 'auctioneer', 'collector'];
    }

    function isValidBuyer(data) {
      return data.keys().hasAll(['id', 'nickname', 'lifetime_debt', 'credit_limit']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nickname is string && data.nickname.size() <= 100 &&
             data.lifetime_debt is number &&
             data.credit_limit is number;
    }

    function isValidSource(data) {
      return data.keys().hasAll(['id', 'name', 'date', 'is_completed', 'is_archived']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.date is string && data.date.size() <= 30 &&
             data.is_completed is bool &&
             data.is_archived is bool;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'source_id', 'buyer_id', 'weight', 'price_per_kg', 'total_price', 'date', 'fish_type', 'added_by']) &&
             data.id is string &&
             data.source_id is string &&
             data.buyer_id is string &&
             data.date is string &&
             data.fish_type is string &&
             data.added_by is string &&
             (data.weight is number) &&
             (data.price_per_kg is number) &&
             (data.total_price is number);
    }

    function isValidDailyCollection(data) {
      return data.keys().hasAll(['id', 'buyer_id', 'date', 'total_owed_today', 'amount_paid', 'is_rolled_over', 'is_approved']) &&
             data.id is string && data.id.size() <= 128 &&
             data.buyer_id is string && data.buyer_id.size() <= 128 &&
             data.date is string && data.date.size() <= 30 &&
             data.total_owed_today is number &&
             data.amount_paid is number &&
             data.is_rolled_over is bool &&
             data.is_approved is bool;
    }

    function isValidSourcePayment(data) {
      let baseLength = data.keys().hasAll(['id', 'source_id', 'date', 'total_kg', 'sale_total', 'amount_paid_to_source', 'commission', 'is_settled']);
      return baseLength &&
             data.id is string && data.id.size() <= 128 &&
             data.source_id is string && data.source_id.size() <= 128 &&
             data.date is string && data.date.size() <= 30 &&
             data.total_kg is number &&
             data.sale_total is number &&
             data.amount_paid_to_source is number &&
             data.commission is number &&
             data.is_settled is bool &&
             (!('items_json' in data) || (data.items_json is string && data.items_json.size() <= 50000));
    }
    
    function isValidSetting(data) {
      return data.keys().hasAll(['key', 'value']) &&
             data.keys().size() == 2 &&
             data.key is string && data.key.size() <= 50 &&
             data.value is string && data.value.size() <= 1000;
    }

    match /users/{userId} {
      allow list, read, write: if true;
    }

    match /buyers/{buyerId} {
      allow list, read, write: if true;
    }

    match /sources/{sourceId} {
      allow list, read, write: if true;
    }

    match /transactions/{transactionId} {
      allow list, read, write: if true;
    }

    match /daily_collections/{collectionId} {
      allow list, read, write: if true;
    }

    match /source_payments/{paymentId} {
      allow list, read, write: if true;
    }

    match /settings/{settingId} {
      allow list, read, write: if true;
    }
  }
}
