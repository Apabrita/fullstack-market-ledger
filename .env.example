# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_BACKEND_URL: Used if frontend is separated from backend (e.g. native Android app). Leave blank otherwise.
VITE_BACKEND_URL=""

# VITE_SUPABASE_URL: URL to your Supabase project (e.g. https://xyz.supabase.co)
VITE_SUPABASE_URL="https://YOUR_SUPABASE_PROJECT_URL"

# VITE_SUPABASE_ANON_KEY: Anonymous key for secure client-side mutations on your schema tables
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Firebase Config (for OAuth Workspace integration fallback)
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_FIREBASE_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
